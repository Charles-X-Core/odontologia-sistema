{
  "name": "vita-mirabilis",
  "version": "1.0.0",
  "description": "Vita Mirabilis - Sistema de Historial Clinico Odontologico",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:backend\" \"sleep 3 && electron .\"",
    "dev:backend": "cd backend && node src/index.js",
    "build": "npm run build:frontend && electron-builder --win && npm run postbuild",
    "build:frontend": "cd frontend && npm run build",
    "pack": "npm run build:frontend && electron-builder --dir && npm run postbuild",
    "postbuild": "node scripts/copy-portable.js",
    "postinstall": "patch-package",
    "seed": "cd backend && node src/seed.js",
    "install:all": "cd backend && npm install && cd ../frontend && npm install && cd .. && npm install"
  },
  "build": {
    "appId": "com.vitamirabilis.odontologia",
    "productName": "Vita Mirabilis",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "backend/src/**/*",
      "backend/package.json",
      "backend/node_modules/**/*",
      "frontend/dist/**/*",
      "node_modules/**/*",
      "portable/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/**",
      "**/electron/**"
    ],
    "extraResources": [],
    "win": {
      "target": "nsis",
      "icon": "electron/logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Vita Mirabilis",
      "installerIcon": "electron/logo.ico",
      "uninstallerIcon": "electron/logo.ico"
    }
  },
  "dependencies": {
    "@puppeteer/browsers": "^2.10.0",
    "bcryptjs": "^2.4.3",
    "concurrently": "^9.0.0",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "express": "^4.21.0",
    "fs-extra": "^11.3.5",
    "jsonfile": "^6.2.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "pdfmake": "^0.3.9",
    "puppeteer-core": "^25.1.0",
    "qrcode": "^1.5.4",
    "universalify": "^2.0.1",
    "whatsapp-web.js": "^1.34.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "patch-package": "^8.0.1"
  }
}
