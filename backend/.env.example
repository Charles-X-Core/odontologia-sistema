# ============================================
# Clinica Dental Pro - Variables de Entorno
# ============================================
# Copia este archivo como .env y completa los valores

# Puerto del servidor
PORT=3001

# JWT Secret
JWT_SECRET=clinica-odontologica-secret-2026

# Base de datos
DB_PATH=./clinica.db

# ============================================
# WhatsApp Cloud API (Meta)
# ============================================
# Obtener en: https://developers.facebook.com
# 1. Crear App -> Tipo Business
# 2. Agregar producto WhatsApp
# 3. Conectar tu numero de WhatsApp Business
# 4. Copiar los valores aqui abajo

WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v21.0
